        });
    </script>
    <script>
        $(document).ready(function () {
            // --- Xử lý Danh mục ---
            $(".frame-danhmuc > ul > li > ul").hide();
            $(".frame-danhmuc > ul > li").click(function (e) {
                $(this).children("ul").slideToggle();
                e.stopPropagation(); // Ngăn lỗi click chồng lên nhau
            });

            // --- Xử lý Ẩn/Hiện LOGIN ---
            $("#btn-login").click(function () {
                $("#login").fadeIn();
                $("#cart").hide(); // Ẩn giỏ hàng nếu đang mở
            });

            $(".close").click(function () {
                $("#login").fadeOut();
            });

            // --- Xử lý Ẩn/Hiện GIỎ HÀNG (Sửa lỗi ở đây) ---
            // Tìm button chứa icon giỏ hàng trong Navbar
            $(".fa-cart-shopping").closest("button").click(function () {
                $("#cart").fadeIn();
                $("#login").hide(); // Ẩn login nếu đang mở
            });

            $(".close-cart").click(function () {
                $("#cart").fadeOut();
            });

            // --- Đóng khi bấm ra ngoài vùng form ---
            $(window).click(function (e) {
                if ($(e.target).is('#login')) $("#login").fadeOut();
                if ($(e.target).is('#cart')) $("#cart").fadeOut();
            });
        });
    </script>
